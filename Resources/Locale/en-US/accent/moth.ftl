# Triad: fluttery wingbeat tics for the Moth accent, appended at MothAccentComponent.flutterChance.
# Kept soft and short -- this is a baseline species accent on every moth's every line, so it must
# stay readable. AppendSuffix slots them in before the sentence's terminal punctuation.
accent-moth-flutter-1 = , bzzt
accent-moth-flutter-2 = , fwzzt
accent-moth-flutter-3 = , mmzzz
