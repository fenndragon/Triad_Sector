# New Brooklyn: the everyman borough accent. The pizzeria owner, the garage mechanic, the guy on the
# corner. NYC working-class phonetic spellings + regular-Joe slang. Tic prefixes are interjections;
# suffixes are everyman address/affirmation (no insults).

# Tics
accent-newbrooklyn-prefix-1 = Ey,
accent-newbrooklyn-prefix-2 = Yo,
accent-newbrooklyn-prefix-3 = Lemme tell ya,
accent-newbrooklyn-prefix-4 = Aw c'mon,

accent-newbrooklyn-suffix-1 = , capiche?
accent-newbrooklyn-suffix-2 = , I'm tellin' ya.
accent-newbrooklyn-suffix-3 = , ya know?
accent-newbrooklyn-suffix-4 = , fuhgeddaboudit.
accent-newbrooklyn-suffix-5 = , no joke.

